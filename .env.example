RESEND_API_KEY=re_xxxxxxxxxxxx
ADMIN_PASSWORD=your-secure-password-min-16-chars
# SITE_URL must exactly match the canonical access URL including protocol and subdomain
# (e.g., https://fotovoltaika.drone-vision.cz — NOT https://www.fotovoltaika.drone-vision.cz)
SITE_URL=https://your-site.netlify.app
# FROM_EMAIL domain (e.g., notifications.drone-vision.cz) must be verified in the Resend dashboard:
# Settings → Domains → Add Domain → verify DNS records
FROM_EMAIL=noreply@notifications.drone-vision.cz
LEAD_MAGNET_PDF_URL=https://your-site.netlify.app/downloads/lead-magnet.pdf
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
QUIZ_NOTIFICATION_EMAILS=mira@dronesoft.cz,david@dronesoft.cz,pavelcermak@hypedigitaly.ai
