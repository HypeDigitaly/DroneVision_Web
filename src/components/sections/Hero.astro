---
import siteData from '../../utils/siteData';
import { t, getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';
import Button from '../ui/Button.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const hero = siteData.hero;
const headline = t(hero, 'headline', lang);
const subheadline = t(hero, 'subheadline', lang);
const ctaPrimaryText = t(hero.ctaPrimary, 'text', lang);
const ctaSecondaryText = hero.ctaSecondary
  ? t(hero.ctaSecondary, 'text', lang)
  : '';
---

<section
  id="hero"
  class="relative min-h-[90vh] flex items-center overflow-hidden bg-[#050505]"
>
  {hero.backgroundImage && (
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-20"
      style={`background-image: url('${hero.backgroundImage}')`}
      aria-hidden="true"
    />
  )}

  <!-- Gradient orb -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-primary/10 blur-[120px] pointer-events-none"
    aria-hidden="true"
  />

  <div class="container-section relative z-10 py-32 text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-4xl mx-auto animate-on-scroll">
      {headline}
    </h1>

    <p class="mt-6 text-xl text-neutral-400 max-w-2xl mx-auto animate-on-scroll" style="animation-delay: 0.15s">
      {subheadline}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-4 animate-on-scroll" style="animation-delay: 0.3s">
      <Button href={getLocalizedHref(hero.ctaPrimary.href, lang)} variant="primary" size="lg">
        {ctaPrimaryText}
      </Button>

      {hero.ctaSecondary && (
        <Button href={getLocalizedHref(hero.ctaSecondary.href, lang)} variant="secondary" size="lg">
          {ctaSecondaryText}
        </Button>
      )}
    </div>
  </div>
</section>
