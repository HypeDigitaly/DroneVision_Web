---
import siteData from '../../utils/siteData';
import { t, getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';
import Button from '../ui/Button.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.cta;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
const subheadline = t(section, 'subheadline', lang);
const buttonText = t(section, 'buttonText', lang);
---

<section id="cta" class="py-24 bg-[#050505] border-t border-white/5 relative overflow-hidden">
  <!-- Glow orbs -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full bg-primary/10 blur-[120px] pointer-events-none"
    aria-hidden="true"
  />
  <div
    class="absolute -bottom-20 right-0 w-[400px] h-[400px] rounded-full bg-primary/5 blur-[100px] pointer-events-none"
    aria-hidden="true"
  />

  <div class="container-section relative z-10 text-center">
    <div class="animate-on-scroll max-w-3xl mx-auto">
      <!-- Subtle badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-8">
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse" aria-hidden="true"></span>
        <span class="text-primary text-sm font-medium">
          {lang === 'en' ? 'Free, no obligation' : 'Zdarma, bez závazků'}
        </span>
      </div>

      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        {headline}
      </h2>

      <p class="text-xl text-neutral-400 leading-relaxed mb-10 max-w-2xl mx-auto">
        {subheadline}
      </p>

      <Button href={getLocalizedHref(section.buttonHref, lang)} variant="primary" size="lg">
        {buttonText}
      </Button>
    </div>
  </div>
</section>
