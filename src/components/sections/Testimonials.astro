---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.testimonials;

if (!section.enabled) return;

const headline = section.headline_cs
  ? t(section, 'headline', lang)
  : '';
---

<section id="testimonials" class="py-24 bg-[#050505] border-t border-white/5">
  <div class="container-section">

    <div class="mb-14 animate-on-scroll">
      <span class="section-number">05</span>
      {headline && (
        <h2 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          {headline}
        </h2>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {section.items.map((item, i) => (
        <div
          class="card p-6 flex flex-col gap-4 animate-on-scroll"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <!-- Decorative quote mark -->
          <span class="text-4xl leading-none text-primary font-serif select-none" aria-hidden="true">"</span>

          <!-- Rating stars -->
          {item.rating && (
            <div class="flex gap-1" aria-label={`${item.rating} z 5 hvězd`}>
              {Array.from({ length: 5 }).map((_, idx) => (
                <svg
                  width="16" height="16" viewBox="0 0 16 16" fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M8 1l1.854 3.756 4.146.603-3 2.924.708 4.129L8 10.5l-3.708 1.912.708-4.129-3-2.924 4.146-.603L8 1z"
                    fill={idx < item.rating! ? '#00A39A' : 'rgba(255,255,255,0.12)'}
                  />
                </svg>
              ))}
            </div>
          )}

          <!-- Quote text -->
          <p class="text-neutral-300 text-sm leading-relaxed italic flex-1">
            {t(item, 'quote', lang)}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t border-white/5">
            {item.image && (
              <img
                src={item.image}
                alt={item.author}
                width="40" height="40"
                class="w-10 h-10 rounded-full object-cover shrink-0 bg-white/10"
                loading="lazy"
              />
            )}
            <div>
              <p class="text-white font-semibold text-sm">{item.author}</p>
              <p class="text-neutral-400 text-xs">
                {t(item, 'role', lang)}, {item.company}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
