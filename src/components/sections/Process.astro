---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.process;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
---

<section id="process" class="py-24 bg-[#060606] border-t border-white/5">
  <div class="container-section">

    <div class="mb-14 animate-on-scroll">
      <span class="section-number">04</span>
      <h2 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {headline}
      </h2>
    </div>

    <div class="relative">
      <!-- Vertical connector line on desktop -->
      <div class="absolute left-[19px] top-6 bottom-6 w-px bg-white/5 hidden md:block" aria-hidden="true" />

      <ol class="space-y-8">
        {section.steps.map((step, i) => (
          <li
            class="flex gap-6 animate-on-scroll"
            style={`animation-delay: ${i * 0.1}s`}
          >
            <div class="shrink-0 w-10 h-10 rounded-full border border-primary/50 bg-primary/10 flex items-center justify-center z-10">
              <span class="text-sm font-bold text-primary">{String(step.number).padStart(2, '0')}</span>
            </div>
            <div class="card p-6 flex-1">
              <h3 class="text-lg font-semibold text-white mb-2">
                {t(step, 'title', lang)}
              </h3>
              <p class="text-neutral-400 text-sm leading-relaxed">
                {t(step, 'description', lang)}
              </p>
            </div>
          </li>
        ))}
      </ol>
    </div>

  </div>
</section>
