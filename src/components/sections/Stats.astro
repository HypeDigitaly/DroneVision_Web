---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.stats;

if (!section.enabled) return;
---

<section id="stats" class="py-16 bg-[#050505] border-t border-white/5">
  <div class="container-section">
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden">
      {section.items.map((item, i) => (
        <div
          class="bg-[#050505] px-8 py-10 flex flex-col items-center text-center animate-on-scroll"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <dd class="text-4xl md:text-5xl font-bold text-white tabular-nums">
            {item.value}<span class="text-primary">{item.suffix ?? ''}</span>
          </dd>
          <dt class="mt-2 text-sm text-neutral-400">
            {t(item, 'label', lang)}
          </dt>
        </div>
      ))}
    </dl>
  </div>
</section>
