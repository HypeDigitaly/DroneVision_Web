---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';
import Icon from '../ui/Icon.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.services;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
---

<section id="services" class="py-24 bg-[#050505] border-t border-white/5">
  <div class="container-section">

    <div class="mb-14 animate-on-scroll">
      <span class="section-number">03</span>
      <h2 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
        {headline}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {section.items.map((item, i) => (
        <div
          class="card p-8 flex flex-col animate-on-scroll"
          style={`animation-delay: ${i * 0.1}s`}
        >
          {item.icon && (
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-5">
              <Icon name={item.icon} size={22} />
            </div>
          )}

          <h3 class="text-xl font-bold text-white mb-3">
            {t(item, 'title', lang)}
          </h3>
          <p class="text-neutral-400 text-sm leading-relaxed mb-6">
            {t(item, 'description', lang)}
          </p>

          <ul class="space-y-2 mb-8 flex-1">
            {item.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-neutral-300">
                <Icon name="check" size={16} class="text-primary shrink-0 mt-0.5" />
                {feature}
              </li>
            ))}
          </ul>

          {item.price && (
            <div class="pt-6 border-t border-white/5">
              <span class="text-2xl font-bold text-white">{item.price} CZK</span>
              {item.priceFrequency && (
                <span class="text-neutral-400 text-sm ml-1">/ {item.priceFrequency}</span>
              )}
            </div>
          )}
        </div>
      ))}
    </div>

  </div>
</section>
