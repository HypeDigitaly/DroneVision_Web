---
import siteData from '../../utils/siteData';
import { getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;

const contactLabel = lang === 'cs' ? 'Kontakt' : 'Contact';
const switchLabel = lang === 'cs' ? 'EN' : 'CS';
---

<nav class="hidden md:flex items-center gap-8" aria-label="Hlavní navigace">
  {siteData.footer.links.map((link) => (
    <a
      href={getLocalizedHref(link.href, lang)}
      class="text-neutral-400 hover:text-white transition-colors text-sm"
    >
      {lang === 'cs' ? link.label_cs : link.label_en}
    </a>
  ))}

  <a
    href={getLocalizedHref('/kontakt', lang)}
    class="bg-primary text-white px-5 py-2 rounded-lg hover:bg-primary-dark transition-colors text-sm font-medium"
  >
    {contactLabel}
  </a>

  <button
    id="lang-switch"
    class="text-neutral-500 hover:text-white text-xs uppercase tracking-wider transition-colors"
    aria-label={lang === 'cs' ? 'Switch to English' : 'Přepnout do češtiny'}
  >
    {switchLabel}
  </button>
</nav>

<script is:inline define:vars={{ currentLang: lang }}>
  (function () {
    var btn = document.getElementById('lang-switch');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var url = new URL(window.location.href);
      if (currentLang === 'cs') {
        url.searchParams.set('lang', 'en');
      } else {
        url.searchParams.delete('lang');
      }
      window.location.href = url.toString();
    });
  })();
</script>
