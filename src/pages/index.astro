---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/sections/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Solution from '../components/sections/Solution.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.astro';
import Stats from '../components/sections/Stats.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
import LeadMagnet from '../components/sections/LeadMagnet.astro';
import CTA from '../components/sections/CTA.astro';
import Contact from '../components/sections/Contact.astro';
import siteData from '../utils/siteData';
import type { Language } from '../types';

export const prerender = false;

const url = Astro.url;
const langParam = url.searchParams.get('lang');

if (langParam === 'cs') {
  const cleanUrl = url.pathname + (url.search.replace(/[?&]lang=cs/, '').replace(/^&/, '?') || '');
  return Astro.redirect(cleanUrl.replace(/\?$/, ''), 301);
}

const cookieLang = Astro.cookies.get('preferredLanguage')?.value;
const lang: Language = langParam === 'en' ? 'en' : cookieLang === 'en' ? 'en' : 'cs';

if (langParam) {
  Astro.cookies.set('preferredLanguage', langParam, { path: '/', maxAge: 31536000, sameSite: 'lax' });
}
---

<BaseLayout lang={lang}>
  <Header lang={lang} />
  <main class="pt-20">
    <Hero lang={lang} />
    {siteData.problem.enabled && <Problem lang={lang} />}
    {siteData.solution.enabled && <Solution lang={lang} />}
    {siteData.services.enabled && <Services lang={lang} />}
    {siteData.process.enabled && <Process lang={lang} />}
    {siteData.stats.enabled && <Stats lang={lang} />}
    {siteData.testimonials.enabled && <Testimonials lang={lang} />}
    {siteData.pricing && siteData.pricing.enabled && <Pricing lang={lang} />}
    {siteData.faq.enabled && <FAQ lang={lang} />}
    {siteData.leadMagnet && siteData.leadMagnet.enabled && <LeadMagnet lang={lang} />}
    {siteData.cta.enabled && <CTA lang={lang} />}
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
