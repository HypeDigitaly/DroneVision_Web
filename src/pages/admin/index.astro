---
export const prerender = false;
---

<!DOCTYPE html>
<html lang="cs" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: Inter, sans-serif; background: #050505; color: #fff; min-height: 100vh; display: flex; flex-direction: column; }
      .wrap { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem; width: 100%; }
      h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 1.5rem; }
      label { display: block; font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-bottom: 0.4rem; }
      input[type="password"] { width: 100%; max-width: 320px; padding: 0.6rem 0.9rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #fff; font-size: 0.95rem; outline: none; }
      input[type="password"]:focus { border-color: #00A39A; }
      .btn { display: inline-flex; align-items: center; padding: 0.55rem 1.2rem; border-radius: 8px; font-size: 0.9rem; font-weight: 500; cursor: pointer; border: none; transition: opacity 0.15s; }
      .btn:hover { opacity: 0.85; }
      .btn-primary { background: #00A39A; color: #fff; }
      .btn-ghost { background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.7); }
      .error { color: #f87171; font-size: 0.875rem; margin-top: 0.75rem; }
      table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin-top: 1.5rem; }
      th { text-align: left; padding: 0.6rem 0.9rem; color: rgba(255,255,255,0.5); font-weight: 500; border-bottom: 1px solid rgba(255,255,255,0.05); white-space: nowrap; }
      td { padding: 0.65rem 0.9rem; border-bottom: 1px solid rgba(255,255,255,0.05); color: rgba(255,255,255,0.8); vertical-align: top; }
      tr:hover td { background: rgba(255,255,255,0.02); }
      .count { color: rgba(255,255,255,0.45); font-size: 0.85rem; margin-bottom: 0.5rem; }
      .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.75rem; }
      #login-view, #admin-view { width: 100%; }
      #admin-view { display: none; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div id="login-view">
        <h1>Admin</h1>
        <form id="login-form">
          <label for="pwd">Heslo</label>
          <input type="password" id="pwd" autocomplete="current-password" required />
          <div style="margin-top:0.9rem;">
            <button type="submit" class="btn btn-primary">Přihlásit se</button>
          </div>
          <p id="login-error" class="error" style="display:none;">Nesprávné heslo.</p>
        </form>
      </div>

      <div id="admin-view">
        <div class="topbar">
          <h1>Leady</h1>
          <button id="logout-btn" class="btn btn-ghost">Odhlásit se</button>
        </div>
        <p id="lead-count" class="count"></p>
        <div id="leads-container"></div>
      </div>
    </div>

    <script is:inline>
      (function () {
        var loginView = document.getElementById('login-view');
        var adminView = document.getElementById('admin-view');
        var loginForm = document.getElementById('login-form');
        var loginError = document.getElementById('login-error');
        var leadCount = document.getElementById('lead-count');
        var leadsContainer = document.getElementById('leads-container');
        var logoutBtn = document.getElementById('logout-btn');

        function showAdmin() {
          loginView.style.display = 'none';
          adminView.style.display = 'block';
        }

        function showLogin() {
          loginView.style.display = 'block';
          adminView.style.display = 'none';
        }

        function escapeHtml(str) {
          if (!str) return '';
          return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
        }

        function truncate(str, n) {
          if (!str) return '';
          return str.length > n ? str.slice(0, n) + '…' : str;
        }

        function renderLeads(leads) {
          leadCount.textContent = 'Celkem: ' + leads.length + ' leadů';
          if (!leads.length) {
            leadsContainer.innerHTML = '<p style="color:rgba(255,255,255,0.4);margin-top:1rem;">Žádné leady.</p>';
            return;
          }
          var rows = leads.map(function (l) {
            var date = l.submittedAt ? new Date(l.submittedAt).toLocaleDateString('cs-CZ') : '—';
            return '<tr>'
              + '<td>' + date + '</td>'
              + '<td>' + escapeHtml(l.name || '—') + '</td>'
              + '<td>' + escapeHtml(l.email || '—') + '</td>'
              + '<td>' + escapeHtml(l.source || '—') + '</td>'
              + '<td>' + escapeHtml(truncate(l.message || l.company || '', 80)) + '</td>'
              + '</tr>';
          }).join('');
          leadsContainer.innerHTML = '<table>'
            + '<thead><tr><th>Datum</th><th>Jméno</th><th>E-mail</th><th>Zdroj</th><th>Zpráva</th></tr></thead>'
            + '<tbody>' + rows + '</tbody>'
            + '</table>';
        }

        function fetchLeads(password) {
          fetch('/api/admin-leads', {
            headers: { 'Authorization': 'Basic ' + btoa('admin:' + password) }
          })
            .then(function (res) {
              if (res.status === 401) {
                sessionStorage.removeItem('adminPwd');
                loginError.textContent = 'Nesprávné heslo.';
                loginError.style.display = 'block';
                showLogin();
                return null;
              }
              return res.json();
            })
            .then(function (data) {
              if (!data) return;
              var leads = Array.isArray(data) ? data : (data.leads || data.data || []);
              showAdmin();
              renderLeads(leads);
            })
            .catch(function () {
              leadsContainer.innerHTML = '<p style="color:#f87171;margin-top:1rem;">Chyba při načítání dat.</p>';
              showAdmin();
            });
        }

        logoutBtn.addEventListener('click', function () {
          sessionStorage.removeItem('adminPwd');
          showLogin();
        });

        loginForm.addEventListener('submit', function (e) {
          e.preventDefault();
          var pwd = document.getElementById('pwd').value;
          loginError.style.display = 'none';
          sessionStorage.setItem('adminPwd', pwd);
          fetchLeads(pwd);
        });

        var saved = sessionStorage.getItem('adminPwd');
        if (saved) {
          fetchLeads(saved);
        }
      })();
    </script>
  </body>
</html>
