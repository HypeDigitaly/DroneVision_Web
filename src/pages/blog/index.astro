---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import Container from '../../components/ui/Container.astro';
import siteData from '../../utils/siteData';
import type { Language } from '../../types';

export const prerender = false;

if (!siteData.blog?.enabled) {
  return Astro.redirect('/', 302);
}

const url = Astro.url;
const langParam = url.searchParams.get('lang');

if (langParam === 'cs') {
  const cleanUrl = url.pathname + (url.search.replace(/[?&]lang=cs/, '').replace(/^&/, '?') || '');
  return Astro.redirect(cleanUrl.replace(/\?$/, ''), 301);
}

const cookieLang = Astro.cookies.get('preferredLanguage')?.value;
const lang: Language = langParam === 'en' ? 'en' : cookieLang === 'en' ? 'en' : 'cs';

if (langParam) {
  Astro.cookies.set('preferredLanguage', langParam, { path: '/', maxAge: 31536000, sameSite: 'lax' });
}

const categories = siteData.blog?.categories ?? [];
const comingSoon = lang === 'en' ? 'Blog articles coming soon.' : 'Články blogu přibývají.';
const categoriesLabel = lang === 'en' ? 'Categories' : 'Kategorie';
---

<BaseLayout title="Blog" lang={lang}>
  <Header lang={lang} />
  <main class="pt-20">
    <Container>
      <div class="py-20">
        <h1 class="text-4xl font-bold text-white mb-4">Blog</h1>

        {categories.length > 0 && (
          <div class="mb-10">
            <p class="text-sm text-white/50 uppercase tracking-widest mb-3">{categoriesLabel}</p>
            <div class="flex flex-wrap gap-2">
              {categories.map((cat) => (
                <span class="px-3 py-1 rounded-full text-sm border border-white/10 text-white/70">
                  {cat}
                </span>
              ))}
            </div>
          </div>
        )}

        <p class="text-white/50 text-lg">{comingSoon}</p>
      </div>
    </Container>
  </main>
  <Footer lang={lang} />
</BaseLayout>
