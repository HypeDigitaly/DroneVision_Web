---
import siteData from '../utils/siteData';
import type { Language } from '../types';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: Language;
  noindex?: boolean;
}

const {
  title = siteData.meta.name,
  description = siteData.meta.description,
  lang = 'cs',
  noindex = false,
} = Astro.props;

const pageTitle =
  title === siteData.meta.name ? title : `${title} | ${siteData.meta.name}`;

const canonicalUrl = `${siteData.meta.siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${siteData.meta.siteUrl}${siteData.meta.ogImage}`;

const orgSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteData.company.name,
  url: siteData.meta.siteUrl,
  logo: `${siteData.meta.siteUrl}${siteData.meta.logo}`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteData.company.address,
    addressLocality: siteData.company.city,
    postalCode: siteData.company.zipCode,
    addressCountry: siteData.company.country,
  },
});
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>

    <!-- SEO -->
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteData.meta.name} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" href={siteData.meta.favicon} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="cs" href={siteData.meta.siteUrl + Astro.url.pathname} />
    <link rel="alternate" hreflang="en" href={siteData.meta.siteUrl + Astro.url.pathname + '?lang=en'} />
    <link rel="alternate" hreflang="x-default" href={siteData.meta.siteUrl + Astro.url.pathname} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Organization schema -->
    <script type="application/ld+json" set:html={orgSchema} />

    <!-- GA4 (consent-gated) -->
    {siteData.meta.gaId && (
      <script
        is:inline
        define:vars={{ gaId: siteData.meta.gaId }}
      >
        // Only load GA4 if the user has consented (cookie 'ga_consent' === '1')
        if (document.cookie.split(';').some(c => c.trim() === 'ga_consent=1')) {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          s.async = true;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        }
      </script>
    )}
  </head>
  <body class="antialiased bg-background text-text min-h-screen">
    <slot />
    <slot name="scripts" />

    <!-- Scroll-triggered animation observer -->
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.animate-on-scroll').forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
