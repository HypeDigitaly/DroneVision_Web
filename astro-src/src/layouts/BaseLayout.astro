---
import siteData from '../utils/siteData';
import type { Language } from '../types';
import '../styles/global.css';

// site.json carries bilingual descriptions and geoCoordinates that are not yet
// reflected in the TypeScript interfaces — cast to access them safely.
const siteRaw = siteData as unknown as Record<string, unknown> & typeof siteData;
const metaRaw = siteRaw.meta as Record<string, unknown> & typeof siteData.meta;
const geoCoordinates = (siteRaw.geoCoordinates ?? { latitude: 0, longitude: 0 }) as {
  latitude: number;
  longitude: number;
};

interface Props {
  title?: string;
  description?: string;
  lang?: Language;
  noindex?: boolean;
}

const {
  title = siteData.meta.name,
  lang = 'cs',
  noindex = false,
} = Astro.props;

// Resolve bilingual description: prefer caller-supplied value, fall back to
// the lang-keyed field in site.json, then the generic description field.
const defaultDescription =
  lang === 'en'
    ? ((metaRaw.description_en as string | undefined) ?? (metaRaw.description as string | undefined) ?? '')
    : ((metaRaw.description_cs as string | undefined) ?? (metaRaw.description as string | undefined) ?? '');

const { description = defaultDescription } = Astro.props;

const pageTitle =
  title === siteData.meta.name ? title : `${title} | ${siteData.meta.name}`;

// Canonical URL reflects the language version currently being rendered.
// Czech is the canonical default (no query param); English appends ?lang=en.
const basePath = `${siteData.meta.siteUrl}${Astro.url.pathname}`;
const canonicalUrl = lang === 'en' ? `${basePath}?lang=en` : basePath;
const ogImageUrl = `${siteData.meta.siteUrl}${siteData.meta.ogImage}`;

// hreflang base paths (always built from siteUrl + pathname, never from
// the current request URL so they stay consistent across environments).
const hreflangCs = `${siteData.meta.siteUrl}${Astro.url.pathname}`;
const hreflangEn = `${siteData.meta.siteUrl}${Astro.url.pathname}?lang=en`;

const localBusinessSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: siteData.company.name,
  image: `${siteData.meta.siteUrl}${siteData.meta.logo}`,
  description: defaultDescription,
  url: siteData.meta.siteUrl,
  telephone: siteData.contact.phone,
  email: siteData.contact.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: siteData.company.address,
    addressLocality: siteData.company.city,
    postalCode: siteData.company.zipCode,
    addressCountry: 'CZ',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: geoCoordinates.latitude,
    longitude: geoCoordinates.longitude,
  },
  areaServed: {
    '@type': 'Country',
    name: siteData.company.country,
  },
  priceRange: '€€',
});

const serviceSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name:
    lang === 'en'
      ? (metaRaw.tagline_en as string | undefined) ?? 'Drone-Based Solar Panel Thermal Inspection'
      : (metaRaw.tagline_cs as string | undefined) ?? 'Inspekce FVE dronem s termovizí',
  description: defaultDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: siteData.company.name,
  },
  areaServed: {
    '@type': 'Country',
    name: siteData.company.country,
  },
  serviceType: 'Drone Thermal Inspection',
});
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{pageTitle}</title>

    <!-- SEO -->
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteData.meta.name} />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'cs_CZ'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'cs_CZ' : 'en_US'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" href={siteData.meta.favicon} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="cs" href={hreflangCs} />
    <link rel="alternate" hreflang="en" href={hreflangEn} />
    <link rel="alternate" hreflang="x-default" href={hreflangCs} />

    <!-- Google Fonts: Outfit (headings) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: LocalBusiness schema -->
    <script type="application/ld+json" set:html={localBusinessSchema} />

    <!-- JSON-LD: Service schema -->
    <script type="application/ld+json" set:html={serviceSchema} />

    <!-- GA4 (consent-gated) -->
    {siteData.meta.gaId && (
      <script
        is:inline
        define:vars={{ gaId: siteData.meta.gaId }}
      >
        // Only load GA4 if the user has consented (cookie 'ga_consent' === '1')
        if (document.cookie.split(';').some(c => c.trim() === 'ga_consent=1')) {
          var s = document.createElement('script');
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          s.async = true;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', gaId);
        }
      </script>
    )}
  </head>
  <body class="antialiased bg-background text-text min-h-screen">
    <slot />
    <slot name="scripts" />

    <!-- Scroll-triggered animation observer -->
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 }
        );
        document.querySelectorAll('.animate-on-scroll').forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
