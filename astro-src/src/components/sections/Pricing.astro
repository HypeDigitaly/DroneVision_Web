---
import siteData from '../../utils/siteData';
import { t, getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';
import Button from '../ui/Button.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.pricing;

if (!section || !section.enabled) return;

const headline = section.headline_cs
  ? t(section, 'headline', lang)
  : '';

const popularLabel = lang === 'en' ? 'Most Popular' : 'Nejoblíbenější';
const setupFeeLabel = lang === 'en' ? 'Setup fee' : 'Jednorázový poplatek';
---

<section id="pricing" class="py-24 bg-[#050505] border-t border-white/5">
  <div class="container-section">

    <div class="mb-14 text-center animate-on-scroll">
      <span class="section-number">08</span>
      {headline && (
        <h2 class="mt-3 text-3xl md:text-4xl lg:text-5xl font-bold text-white">
          {headline}
        </h2>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {section.tiers.map((tier, i) => {
        const name = t(tier, 'name', lang);
        const period = t(tier, 'period', lang);
        const description = t(tier, 'description', lang);
        const ctaText = t(tier.cta, 'text', lang);

        return (
          <div
            class={[
              'card p-6 flex flex-col gap-5 relative animate-on-scroll',
              tier.highlighted ? 'border-primary ring-1 ring-primary' : '',
            ].join(' ')}
            style={`animation-delay: ${i * 0.1}s`}
          >
            {tier.highlighted && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="px-3 py-1 rounded-full bg-primary text-white text-xs font-semibold uppercase tracking-wide">
                  {popularLabel}
                </span>
              </div>
            )}

            <!-- Tier name + price -->
            <div>
              <p class="text-neutral-400 text-sm font-medium mb-3">{name}</p>
              <div class="flex items-end gap-1">
                <span class="text-4xl font-bold text-white">{Number(tier.price).toLocaleString('cs-CZ')}</span>
                <span class="text-neutral-400 text-sm pb-1 ml-1">{tier.currency} / {period}</span>
              </div>
              {tier.setupFee && (
                <p class="text-neutral-500 text-xs mt-1">
                  + {setupFeeLabel}: {tier.setupFee} {tier.currency}
                </p>
              )}
            </div>

            <!-- Description -->
            <p class="text-neutral-400 text-sm leading-relaxed border-t border-white/5 pt-4">
              {description}
            </p>

            <!-- Features list -->
            <ul class="flex flex-col gap-2.5 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm">
                  {feature.included ? (
                    <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <circle cx="8" cy="8" r="8" fill="rgba(0,163,154,0.15)"/>
                      <path d="M4.5 8l2.5 2.5 4.5-5" stroke="#00A39A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  ) : (
                    <svg class="shrink-0 mt-0.5" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                      <circle cx="8" cy="8" r="8" fill="rgba(255,255,255,0.05)"/>
                      <path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  )}
                  <span class={feature.included ? 'text-neutral-300' : 'text-neutral-500'}>
                    {t(feature, 'text', lang)}
                  </span>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <div class="pt-2">
              <Button
                href={getLocalizedHref(tier.cta.href, lang)}
                variant={tier.highlighted ? 'primary' : 'secondary'}
                size="md"
                class="w-full justify-center"
              >
                {ctaText}
              </Button>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
