---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.faq;

if (!section.enabled) return;

const headline = section.headline_cs
  ? t(section, 'headline', lang)
  : '';
---

<section id="faq" class="py-28 relative overflow-hidden section-glow" style="background: linear-gradient(180deg, #050505 0%, #07070c 50%, #050505 100%);">
  <div class="container-section relative z-10">

    <div class="mb-16 text-center animate-on-scroll">
      <span class="section-number">06</span>
      {headline && (
        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold text-white">
          {headline}
        </h2>
      )}
    </div>

    <div class="max-w-3xl mx-auto flex flex-col gap-3">
      {section.items.map((item, i) => (
        <div
          class="card overflow-hidden animate-on-scroll"
          style={`animation-delay: ${i * 0.08}s`}
          data-faq-item
        >
          <button
            class="w-full flex items-center justify-between gap-4 px-6 py-5 text-left cursor-pointer"
            aria-expanded="false"
          >
            <span class="text-white font-medium leading-snug">
              {t(item, 'question', lang)}
            </span>
            <!-- Chevron icon -->
            <svg
              class="shrink-0 text-neutral-400 transition-transform duration-300"
              width="20" height="20" viewBox="0 0 20 20" fill="none"
              aria-hidden="true"
            >
              <path d="M5 7.5l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div
            class="faq-answer overflow-hidden"
            style="max-height: 0; transition: max-height 0.3s ease;"
          >
            <p class="px-6 pb-5 text-neutral-400 text-sm leading-relaxed">
              {t(item, 'answer', lang)}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-faq-item]').forEach((item) => {
    const btn = item.querySelector<HTMLButtonElement>('button');
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    const chevron = btn?.querySelector<SVGElement>('svg');
    if (!btn || !answer) return;

    btn.addEventListener('click', () => {
      const isOpen = item.dataset['open'] === 'true';

      // Close all other items
      document.querySelectorAll<HTMLElement>('[data-faq-item]').forEach((other) => {
        if (other !== item) {
          other.dataset['open'] = 'false';
          const otherAnswer = other.querySelector<HTMLElement>('.faq-answer');
          const otherBtn = other.querySelector<HTMLButtonElement>('button');
          const otherChevron = otherBtn?.querySelector<SVGElement>('svg');
          if (otherAnswer) otherAnswer.style.maxHeight = '0';
          if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
          if (otherChevron) otherChevron.style.transform = '';
        }
      });

      // Toggle current
      if (isOpen) {
        item.dataset['open'] = 'false';
        answer.style.maxHeight = '0';
        btn.setAttribute('aria-expanded', 'false');
        if (chevron) chevron.style.transform = '';
      } else {
        item.dataset['open'] = 'true';
        answer.style.maxHeight = answer.scrollHeight + 'px';
        btn.setAttribute('aria-expanded', 'true');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
