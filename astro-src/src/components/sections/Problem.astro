---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';
import Icon from '../ui/Icon.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.problem;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
---

<section id="problem" class="py-28 relative overflow-hidden section-glow" style="background: linear-gradient(180deg, #050505 0%, #0a0508 50%, #050505 100%);">
  <!-- Subtle red-tinted orb to evoke "danger/problem" -->
  <div class="absolute top-1/2 right-0 w-[400px] h-[400px] rounded-full blur-[120px] pointer-events-none" style="background: rgba(212, 0, 116, 0.04);" aria-hidden="true" />

  <div class="container-section relative z-10">

    <div class="mb-16 max-w-2xl animate-on-scroll">
      <span class="section-number">01</span>
      <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold text-white">
        {headline}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {section.items.map((item, i) => (
        <div
          class="card p-6 flex gap-5 group hover:scale-[1.01] animate-on-scroll"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary transition-all group-hover:bg-primary/20 group-hover:scale-105">
            <Icon name={item.icon} size={22} />
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-2">
              {t(item, 'title', lang)}
            </h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              {t(item, 'description', lang)}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
