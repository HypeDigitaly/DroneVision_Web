---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';
import Icon from '../ui/Icon.astro';
import DroneIllustration from '../ui/DroneIllustration.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.solution;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
const description = t(section, 'description', lang);
---

<section id="solution" class="py-28 relative overflow-hidden section-glow" style="background: linear-gradient(180deg, #050505 0%, #06060e 50%, #050505 100%);">
  <!-- Accent orb -->
  <div class="absolute top-1/3 left-0 w-[400px] h-[400px] rounded-full blur-[120px] pointer-events-none" style="background: rgba(212, 0, 116, 0.04);" aria-hidden="true" />

  <div class="container-section relative z-10">

    <!-- Two-column layout: text left, drone illustration right -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">
      <div class="animate-on-scroll">
        <span class="section-number">02</span>
        <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold text-white">
          {headline}
        </h2>
        <p class="mt-5 text-lg text-neutral-400 leading-relaxed">
          {description}
        </p>
      </div>
      <div class="animate-on-scroll flex justify-center" style="animation-delay: 0.2s;">
        <DroneIllustration variant="scanning" class="w-full max-w-[380px]" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {section.features.map((feature, i) => (
        <div
          class="card p-6 flex gap-5 group hover:scale-[1.01] animate-on-scroll"
          style={`animation-delay: ${i * 0.12}s`}
        >
          {feature.icon && (
            <div class="shrink-0 w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary transition-all group-hover:bg-primary/20 group-hover:scale-105">
              <Icon name={feature.icon} size={22} />
            </div>
          )}
          <div>
            <h3 class="text-lg font-bold text-white mb-2">
              {t(feature, 'title', lang)}
            </h3>
            <p class="text-neutral-400 text-sm leading-relaxed">
              {t(feature, 'description', lang)}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
