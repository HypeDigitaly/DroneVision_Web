---
import siteData from '../../utils/siteData';
import { t, getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const footer = siteData.footer;
const company = siteData.company;
const contact = siteData.contact;
const social = siteData.social;

// Replace {year} placeholder with the current year at build/render time
const currentYear = new Date().getFullYear();
const copyrightRaw = t(footer, 'copyright', lang);
const copyright = copyrightRaw.replace('{year}', String(currentYear));

const certificateText = t(footer, 'certificate', lang);

// Legal links come exclusively from footer.links in site.json — no duplicates
const legalLinks = (footer.links ?? []).map((link) => ({
  label: t(link, 'label', lang),
  href: getLocalizedHref(link.href, lang),
}));
---

<footer id="footer" class="bg-[#050505] border-t border-white/5 pt-16 pb-8">
  <div class="container-section">

    <!-- Top grid: Company info | UCL Certificate | Social + Legal -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 pb-12 border-b border-white/5">

      <!-- Column 1: Company legal info + contact -->
      <div>
        <p class="text-lg font-bold text-white mb-3">{company.name}</p>
        <address class="not-italic text-sm text-neutral-400 space-y-1">
          <p>{company.address}</p>
          <p>{company.zipCode} {company.city}</p>
          {company.ico && <p>IČO: {company.ico}</p>}
          {company.dic && <p>DIČ: {company.dic}</p>}
        </address>
        <div class="mt-4 space-y-1 text-sm text-neutral-400">
          <p>
            <a
              href={`mailto:${contact.email}`}
              class="hover:text-white transition-colors"
            >
              {contact.email}
            </a>
          </p>
          <p>
            <a
              href={`tel:${contact.phone.replace(/\s/g, '')}`}
              class="hover:text-white transition-colors"
            >
              {contact.phone}
            </a>
          </p>
        </div>
      </div>

      <!-- Column 2: UCL / CAA certificate -->
      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {lang === 'cs' ? 'Oprávnění ÚCL' : 'CAA Certificate'}
        </p>
        <p class="text-sm text-neutral-400 leading-relaxed">
          {certificateText}
        </p>
      </div>

      <!-- Column 3: Links -->
      <div>
        <!-- Partner sites -->
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
          {lang === 'cs' ? 'Naše weby' : 'Our Websites'}
        </p>
        <ul class="space-y-2 mb-6">
          <li>
            <a href="https://drone-vision.cz" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-400 hover:text-primary transition-colors">
              drone-vision.cz
            </a>
          </li>
          <li>
            <a href="https://drone-soft.cz" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-400 hover:text-primary transition-colors">
              drone-soft.cz
            </a>
          </li>
        </ul>

        {social.facebook && (
          <>
            <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
              {lang === 'cs' ? 'Sledujte nás' : 'Follow Us'}
            </p>
            <div class="flex gap-3 mb-6">
              <a
                href={social.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="text-neutral-400 hover:text-primary transition-colors text-sm"
              >
                Facebook
              </a>
            </div>
          </>
        )}

        {legalLinks.length > 0 && (
          <>
            <p class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
              {lang === 'cs' ? 'Právní informace' : 'Legal'}
            </p>
            <ul class="space-y-2">
              {legalLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-neutral-400 hover:text-white transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </>
        )}
      </div>

    </div>

    <!-- Copyright -->
    <p class="mt-8 text-sm text-neutral-500 text-center">{copyright}</p>

  </div>
</footer>
