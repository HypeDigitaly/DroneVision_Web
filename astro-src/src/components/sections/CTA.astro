---
import siteData from '../../utils/siteData';
import { t, getLocalizedHref } from '../../utils/i18n';
import type { Language } from '../../types';
import Button from '../ui/Button.astro';
import DroneIllustration from '../ui/DroneIllustration.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.cta;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
const subheadline = t(section, 'subheadline', lang);
const buttonText = t(section, 'buttonText', lang);
---

<section id="cta" class="cta-section py-28 relative overflow-hidden">
  <!-- Dramatic glow orbs -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] rounded-full blur-[150px] pointer-events-none"
    style="background: rgba(212, 0, 116, 0.12);"
    aria-hidden="true"
  />
  <div
    class="absolute -bottom-20 right-[10%] w-[400px] h-[400px] rounded-full blur-[120px] pointer-events-none"
    style="background: rgba(212, 0, 116, 0.06);"
    aria-hidden="true"
  />
  <div
    class="absolute top-[20%] left-[5%] w-[250px] h-[250px] rounded-full blur-[100px] pointer-events-none"
    style="background: rgba(212, 0, 116, 0.04);"
    aria-hidden="true"
  />

  <!-- Grid overlay -->
  <div class="absolute inset-0 pointer-events-none" style="
    background-image: linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, transparent 70%);
  " aria-hidden="true" />

  <!-- Overhead drone illustration -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[400px] opacity-15 pointer-events-none">
    <DroneIllustration variant="overhead" />
  </div>

  <!-- Top/bottom gradient borders -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent" aria-hidden="true" />
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent" aria-hidden="true" />

  <div class="container-section relative z-10 text-center">
    <div class="animate-on-scroll max-w-3xl mx-auto">
      <!-- Badge with pulse -->
      <div class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-primary/10 border border-primary/20 mb-10">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary/60" aria-hidden="true"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary" aria-hidden="true"></span>
        </span>
        <span class="text-primary text-sm font-semibold tracking-wide">
          {lang === 'en' ? 'Free consultation' : 'Konzultace zdarma'}
        </span>
      </div>

      <h2 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-[1.05] mb-7">
        {headline}
      </h2>

      <p class="text-xl text-neutral-400 leading-relaxed mb-12 max-w-2xl mx-auto">
        {subheadline}
      </p>

      <div class="cta-button-wrapper">
        <Button href={getLocalizedHref(section.buttonHref, lang)} variant="primary" size="lg">
          {buttonText}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(180deg, #050505 0%, #0c0610 40%, #0a0510 60%, #050505 100%);
  }

  .cta-button-wrapper {
    display: inline-block;
    animation: pulseGlow 3s ease-in-out infinite;
  }

  @keyframes pulseGlow {
    0%, 100% { filter: drop-shadow(0 0 10px rgba(212, 0, 116, 0.2)); }
    50% { filter: drop-shadow(0 0 25px rgba(212, 0, 116, 0.4)); }
  }
</style>
