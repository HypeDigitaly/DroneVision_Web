---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';
import Icon from '../ui/Icon.astro';
import DroneIllustration from '../ui/DroneIllustration.astro';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.services;

if (!section.enabled) return;

const headline = t(section, 'headline', lang);
---

<section id="services" class="py-28 relative overflow-hidden section-glow" style="background: linear-gradient(180deg, #050505 0%, #070709 50%, #050505 100%);">
  <!-- Background panel detail illustration -->
  <div class="hidden lg:block absolute top-[15%] right-[2%] w-[250px] opacity-25 pointer-events-none">
    <DroneIllustration variant="panel-detail" />
  </div>
  <div class="hidden lg:block absolute bottom-[10%] left-[3%] w-[200px] opacity-20 pointer-events-none" style="transform: rotate(15deg);">
    <DroneIllustration variant="panel-detail" />
  </div>

  <div class="container-section relative z-10">

    <div class="mb-16 animate-on-scroll">
      <span class="section-number">03</span>
      <h2 class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold text-white">
        {headline}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {section.items.map((item, i) => (
        <div
          class="card p-8 flex flex-col group hover:scale-[1.01] animate-on-scroll"
          style={`animation-delay: ${i * 0.12}s`}
        >
          {item.icon && (
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-6 transition-all group-hover:bg-primary/20 group-hover:scale-105">
              <Icon name={item.icon} size={24} />
            </div>
          )}

          <h3 class="text-xl font-bold text-white mb-3">
            {t(item, 'title', lang)}
          </h3>
          <p class="text-neutral-400 text-sm leading-relaxed mb-6">
            {t(item, 'description', lang)}
          </p>

          <ul class="space-y-2.5 mb-8 flex-1">
            {item.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm text-neutral-300">
                <span class="shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-primary/60" aria-hidden="true" />
                {lang === 'en' ? feature.text_en : feature.text_cs}
              </li>
            ))}
          </ul>

          {item.price && (
            <div class="pt-6 border-t border-white/5">
              <span class="text-2xl font-bold text-white">{item.price} CZK</span>
              {item.priceFrequency && (
                <span class="text-neutral-400 text-sm ml-1">/ {item.priceFrequency}</span>
              )}
            </div>
          )}
        </div>
      ))}
    </div>

  </div>
</section>
