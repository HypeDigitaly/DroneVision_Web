---
import siteData from '../../utils/siteData';
import { t } from '../../utils/i18n';
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;
const section = siteData.leadMagnet;

if (!section || !section.enabled) return;

const title = t(section, 'title', lang);
const description = t(section, 'description', lang);

const labels = {
  submit:   lang === 'en' ? 'Get Free Access'  : 'Získat zdarma',
  sending:  lang === 'en' ? 'Sending…'          : 'Odesílám…',
  success:  lang === 'en' ? 'Check your inbox! The download link is on its way.' : 'Zkontrolujte inbox! Odkaz ke stažení je na cestě.',
  error:    lang === 'en' ? 'Something went wrong. Please try again.' : 'Něco se pokazilo. Zkuste to znovu.',
  freeLabel: lang === 'en' ? '100% Free'        : '100% Zdarma',
};
---

<section id="lead-magnet" class="py-24 bg-[#050505] border-t border-white/5 relative overflow-hidden">
  <!-- Background glow -->
  <div
    class="absolute -top-20 right-0 w-[500px] h-[500px] rounded-full bg-primary/5 blur-[100px] pointer-events-none"
    aria-hidden="true"
  />

  <div class="container-section relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: copy + form -->
      <div class="animate-on-scroll">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/20 mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00A39A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span class="text-primary text-xs font-semibold uppercase tracking-widest">{labels.freeLabel}</span>
        </div>

        <h2 class="text-3xl md:text-4xl font-bold text-white leading-snug mb-4">
          {title}
        </h2>
        <p class="text-neutral-400 leading-relaxed mb-8">
          {description}
        </p>

        <form id="lm-form" class="flex flex-col gap-4" novalidate>
          <!-- Honeypot -->
          <input type="text" name="_honeypot" style="display:none" tabindex="-1" autocomplete="off" />

          {section.formFields.map((field) => (
            <div>
              <label for={`lm-${field.name}`} class="text-sm text-neutral-400 mb-2 block">
                {t(field, 'label', lang)}
                {field.required && <span class="text-primary ml-0.5">*</span>}
              </label>
              <input
                id={`lm-${field.name}`}
                type={field.type as any}
                name={field.name}
                required={field.required}
                class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-neutral-500 focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary transition"
              />
            </div>
          ))}

          <div id="lm-msg" class="hidden text-sm px-4 py-3 rounded-lg" role="alert"></div>

          <button
            id="lm-submit"
            type="submit"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-medium rounded-lg bg-primary text-white hover:bg-primary-light transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            {labels.submit}
          </button>
        </form>
      </div>

      <!-- Right: PDF mock -->
      <div class="animate-on-scroll flex justify-center" style="animation-delay: 0.15s">
        <div class="relative w-64 h-80">
          <!-- Shadow stack -->
          <div class="absolute top-4 left-4 w-full h-full rounded-xl bg-white/5 border border-white/5"></div>
          <div class="absolute top-2 left-2 w-full h-full rounded-xl bg-white/5 border border-white/5"></div>
          <!-- Main card -->
          <div class="relative w-full h-full rounded-xl bg-[#0A0A0A] border border-white/10 flex flex-col items-center justify-center gap-4 p-6">
            <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#00A39A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
            </div>
            <div class="text-center">
              <p class="text-primary text-xs font-semibold uppercase tracking-widest mb-1">PDF Checklist</p>
              <p class="text-white text-sm font-medium leading-snug">15 stránek</p>
              <p class="text-neutral-500 text-xs mt-1">500+ stažení</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script define:vars={{ submitLabel: labels.submit, sendingLabel: labels.sending, successMsg: labels.success, errorMsg: labels.error }}>
  const form = document.getElementById('lm-form');
  const submitBtn = document.getElementById('lm-submit');
  const msgBox = document.getElementById('lm-msg');

  if (form && submitBtn && msgBox) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formEl = /** @type {HTMLFormElement} */ (form);
      const data = Object.fromEntries(new FormData(formEl));

      if (data['_honeypot']) return;

      submitBtn.setAttribute('disabled', 'true');
      submitBtn.textContent = sendingLabel;
      msgBox.className = 'hidden text-sm px-4 py-3 rounded-lg';

      try {
        const res = await fetch('/api/lead-magnet', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          msgBox.textContent = successMsg;
          msgBox.className = 'text-sm px-4 py-3 rounded-lg bg-primary/10 border border-primary/30 text-primary';
          formEl.reset();
        } else {
          throw new Error('server');
        }
      } catch {
        msgBox.textContent = errorMsg;
        msgBox.className = 'text-sm px-4 py-3 rounded-lg bg-red-500/10 border border-red-500/30 text-red-400';
      } finally {
        submitBtn.removeAttribute('disabled');
        submitBtn.textContent = submitLabel;
      }
    });
  }
</script>
