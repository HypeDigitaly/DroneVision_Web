---
import type { Language } from '../../types';

interface Props {
  lang?: Language;
}

const { lang = 'cs' } = Astro.props;

const contactLabel = lang === 'cs' ? 'Kontakt' : 'Contact';
const switchLabel = lang === 'cs' ? 'EN' : 'CS';
---

<nav class="hidden md:flex items-center gap-6" aria-label={lang === 'cs' ? 'Hlavní navigace' : 'Main navigation'}>
  <a
    href="https://drone-vision.cz"
    target="_blank"
    rel="noopener noreferrer"
    class="text-neutral-400 hover:text-primary text-sm transition-colors"
  >
    Drone Vision
  </a>
  <a
    href="https://drone-soft.cz"
    target="_blank"
    rel="noopener noreferrer"
    class="text-neutral-400 hover:text-primary text-sm transition-colors"
  >
    DroneSoft
  </a>
  <a
    href="#kontakt"
    class="bg-primary text-white px-5 py-2 rounded-lg hover:bg-primary-dark transition-colors text-sm font-medium"
  >
    {contactLabel}
  </a>

  <button
    id="lang-switch"
    class="text-neutral-500 hover:text-white text-xs uppercase tracking-wider transition-colors"
    aria-label={lang === 'cs' ? 'Switch to English' : 'Přepnout do češtiny'}
  >
    {switchLabel}
  </button>
</nav>

<script is:inline define:vars={{ currentLang: lang }}>
  (function () {
    var btn = document.getElementById('lang-switch');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var url = new URL(window.location.href);
      if (currentLang === 'cs') {
        url.searchParams.set('lang', 'en');
      } else {
        url.searchParams.set('lang', 'cs');
      }
      window.location.href = url.toString();
    });
  })();
</script>
