---
interface Props {
  hover?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  hover = false,
  padding = 'md',
  class: className = '',
} = Astro.props;

const paddingClasses: Record<string, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const hoverClasses = hover ? 'hover:border-white/10 hover:-translate-y-1' : '';
const classes = ['card', paddingClasses[padding], hoverClasses, className].filter(Boolean).join(' ');
---

<div class={classes}>
  <slot />
</div>
